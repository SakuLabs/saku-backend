# ===== App =====
# Port the NestJS server listens on (defaults to 3001 if unset)
PORT=3001

# Environment: development | production | test
NODE_ENV=development

# ===== Database (Prisma + Postgres) =====
# Used by Prisma client, migrations, and seed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saku?schema=public

# ===== Auth (JWT) =====
# Secret used to sign JWT tokens. MUST be set in production.
JWT_SECRET=replace-me-with-a-long-random-string
# Token lifetime (zeit/ms format: 60s, 15m, 24h, 7d). Defaults to 24h.
JWT_EXPIRES_IN=24h

# ===== API Docs (Scalar) =====
# Basic-auth credentials for /docs and /docs/json. Required in all envs.
DOCS_USER=admin
DOCS_PASS=replace-me-with-a-strong-password

# ===== Cloudinary (avatar uploads) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI agent (OpenAI-compatible LLM, e.g. MiMo)
LLM_BASE_URL=https://your-mimo-host/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=30000

# Optional: path to the agent system-prompt template (default: prompts/agent-system.md)
AGENT_PROMPT_FILE=prompts/agent-system.md

# Master switch for the AI agent. Must be exactly "true" to enable /agent/chat.
# Left off, the chat endpoint returns 503 and spends no LLM tokens.
AGENT_ENABLED=false
